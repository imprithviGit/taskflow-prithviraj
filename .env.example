# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=taskflow

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production
JWT_SECRET=super-secret-jwt-key-change-in-production

# ── Frontend ──────────────────────────────────────────────────────────────────
# The URL the browser uses to reach the backend.
# Keep this as localhost:8080 when running via docker compose on your machine.
VITE_API_URL=http://localhost:8080

# ── Backend (local dev only, not needed for docker compose) ───────────────────
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable
PORT=8080
MIGRATIONS_PATH=file://migrations
